<?xml version="1.0" encoding="UTF-8"?>
<!--
    OSGi Metatype descriptor for the usr:coordinatorLRA-2.0 Liberty feature.

    Declaring this file at OSGI-INF/metatype/metatype.xml inside the bundle
    causes Liberty to surface <lraCoordinatorStore> in server.xml with full
    tooling support (auto-complete, validation, hover documentation).

    Usage in server.xml — file store (default):
        <lraCoordinatorStore storeType="file"
                             storeDir="${server.output.dir}/lra-logs"/>

    Usage in server.xml — database store (references a Liberty <dataSource>):
        <dataSource id="LraCoordinatorDS" jndiName="jdbc/LraCoordinatorDS">
            ...
        </dataSource>

        <lraCoordinatorStore storeType="db"
                             dataSourceRef="jdbc/LraCoordinatorDS"
                             tablePrefix="lra_"/>

    Liberty maps the element name to the OCD id "lraCoordinatorStore" and the
    pid "com.ibm.saga.coordinatorlra.store", then delivers the config as a
    Dictionary to the ManagedService registered under that pid.
-->
<metatype:MetaData xmlns:metatype="http://www.osgi.org/xmlns/metatype/v1.3.0"
                   xmlns:ibm="http://www.ibm.com/xmlns/appserv/metatype/v1"
                   xmlns:ibmui="http://www.ibm.com/xmlns/appserv/metatype/ui/v1">

    <OCD id="lraCoordinatorStore"
         name="LRA Coordinator Store"
         description="Configures the transaction-log store used by the embedded Narayana LRA coordinator (usr:coordinatorLRA-2.0).">

        <AD id="storeType"
            name="Store type"
            description="Transaction-log storage backend: 'file' (default) writes logs to the local file system; 'db' uses a Liberty-managed DataSource referenced by dataSourceRef."
            type="String"
            required="false"
            default="file">
            <Option label="File store (local filesystem)" value="file"/>
            <Option label="Database store (Liberty DataSource)" value="db"/>
        </AD>

        <!-- ── File store options ──────────────────────────────────────────── -->

        <AD id="storeDir"
            name="Store directory"
            description="Directory for file-based transaction logs (storeType='file'). The token ${server.output.dir} is expanded to the Liberty server output directory."
            type="String"
            required="false"
            default="${server.output.dir}/lra-logs"/>

        <!-- ── Database store options ──────────────────────────────────────── -->

        <AD id="dataSourceRef"
            name="DataSource JNDI name"
            description="JNDI name of the Liberty &lt;dataSource&gt; element to use for transaction-log storage (storeType='db'). The DataSource must be declared in the same server.xml. Example: jdbc/LraCoordinatorDS"
            type="String"
            required="false"
            default="jdbc/LraCoordinatorDS"/>

        <AD id="tablePrefix"
            name="Table prefix"
            description="Prefix applied to Arjuna object-store table names (storeType='db')."
            type="String"
            required="false"
            default="lra_"/>

    </OCD>

    <Designate pid="com.ibm.saga.coordinatorlra.store">
        <Object ocdref="lraCoordinatorStore"/>
    </Designate>

</metatype:MetaData>
