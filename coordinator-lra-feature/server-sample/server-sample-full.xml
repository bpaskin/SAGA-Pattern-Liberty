<?xml version="1.0" encoding="UTF-8"?>
<!--
    ╔══════════════════════════════════════════════════════════════════════╗
    ║  DEDICATED LRA COORDINATOR SERVER                                    ║
    ║                                                                      ║
    ║  This server runs usr:coordinatorLRA-2.0 ONLY.                       ║
    ║  • Do NOT deploy application WARs, EARs, or add <application>.       ║
    ║  • Do NOT place anything in dropins/.                                 ║
    ║  • Do NOT add mpHealth, mpMetrics, servlet, or jakartaee features.   ║
    ║                                                                      ║
    ║  Business microservices belong on their own Liberty servers.         ║
    ║  They reach this coordinator via usr:clientLRA-2.0 and the          ║
    ║  <lraCoordinator host="…" port="8070"/> element.                     ║
    ╚══════════════════════════════════════════════════════════════════════╝

    PREREQUISITES
    ─────────────
    1. Build the feature ZIP:
         cd coordinator-lra-feature
         mvn clean package

    2. Install it into your Liberty user directory:
         unzip feature/target/coordinatorLRA-2.0-feature.zip -d /path/to/wlp/usr
       Or use the helper script:
         ./install-feature.sh /path/to/wlp/usr

    3. Copy (or symlink) this file to your server's config directory:
         cp server-sample-full.xml /path/to/wlp/usr/servers/<serverName>/server.xml

    REST API endpoint once running:
         http://<host>:8070/lra-coordinator
-->
<server description="LRA coordinator — dedicated server (usr:coordinatorLRA-2.0)">

    <!-- ════════════════════════════════════════════════════════════════════
         FEATURES
         Choose ONE Jakarta EE generation. Both EE 10 and EE 11 are supported.
         Add jdbc-4.3 and jndi-1.0 only when storeType="db" is used.
         ════════════════════════════════════════════════════════════════════ -->
    <featureManager>

        <!-- ── Jakarta EE 11 (Liberty 24.0.0.1+) — recommended ───────── -->
        <feature>restfulWS-4.0</feature>   <!-- JAX-RS 4.0  -->
        <feature>jsonb-3.0</feature>       <!-- JSON-B 3.0  -->
        <feature>jsonp-2.1</feature>       <!-- JSON-P 2.1  -->
        <feature>cdi-4.1</feature>         <!-- CDI 4.1     -->

        <!-- ── Jakarta EE 10 alternative — replace the four lines above ──
        <feature>restfulWS-3.1</feature>
        <feature>jsonb-3.0</feature>
        <feature>jsonp-2.1</feature>
        <feature>cdi-4.0</feature>
        -->

        <!-- The coordinator user feature — must be installed first (see above) -->
        <feature>usr:coordinatorLRA-2.0</feature>

        <!-- Required for <dataSource> and JNDI lookup when storeType="db" -->
        <feature>jdbc-4.3</feature>
        <feature>jndi-1.0</feature>

    </featureManager>


    <!-- ════════════════════════════════════════════════════════════════════
         HTTP ENDPOINT
         The coordinator REST API is served at:
           http://<host>:${lra.coordinator.http.port}/lra-coordinator

         Client services point to this server with (in their own server.xml):
           <lraCoordinator host="<this-server-hostname>" port="8070"/>

         Override ports at runtime via environment variables:
           LRA_COORDINATOR_HTTP_PORT=8070
           LRA_COORDINATOR_HTTPS_PORT=8470
         ════════════════════════════════════════════════════════════════════ -->
    <variable name="lra.coordinator.http.port"  defaultValue="8070"/>
    <variable name="lra.coordinator.https.port" defaultValue="8470"/>

    <httpEndpoint id="defaultHttpEndpoint"
                  host="*"
                  httpPort="${lra.coordinator.http.port}"
                  httpsPort="${lra.coordinator.https.port}"/>


    <!-- ════════════════════════════════════════════════════════════════════
         TRANSACTION LOG STORE
         Choose ONE option below.  Activate it by keeping only that block
         (comment out or remove the other).

         Live changes to <lraCoordinatorStore> in a running server are applied
         without a full server restart — the coordinator restarts internally.
         ════════════════════════════════════════════════════════════════════ -->

    <!--
        ── Option A: File store (default — no database required) ────────────
        Transaction logs are written to the local file system.
        Best for: development, single-node deployments, quick start.

        storeDir  — Directory for log files.
                    ${server.output.dir} expands to the Liberty server output
                    directory (e.g. wlp/usr/servers/<serverName>/).
                    The directory is created automatically if it does not exist.

        Remove the jdbc-4.3 and jndi-1.0 features above if using this option.
    -->
    <lraCoordinatorStore storeType="file"
                         storeDir="${server.output.dir}/lra-logs"/>

    <!--
        ── Option B: Database store (Liberty DataSource — durable across restarts) ──
        Transaction logs are stored in a database via a Liberty-managed <dataSource>.
        Best for: production, multi-node, high-availability deployments.

        How it works:
          dataSourceRef points to the jndiName of a <dataSource> in this server.xml.
          Liberty owns the connection pool, credentials, SSL configuration, and driver
          loading.  No raw JDBC URL or password appears inside <lraCoordinatorStore>.

        tablePrefix — Prefix for Arjuna object-store table names.
                      Default "lra_" produces tables: lra_JBOSSTS, lra_JBOSSTSSHA, …
                      The coordinator creates these tables automatically on first start.

        IMPORTANT: The database schema and user must exist before starting the server.
                   The PostgreSQL JDBC driver must be placed in the shared resources
                   directory referenced by <library> (see below).

    <variable name="db.host"     defaultValue="localhost"/>
    <variable name="db.port"     defaultValue="5432"/>
    <variable name="db.name"     defaultValue="sagadb"/>
    <variable name="db.user"     defaultValue="saga"/>
    <variable name="db.password" defaultValue="saga"/>

    <dataSource id="LraCoordinatorDS" jndiName="jdbc/LraCoordinatorDS">
        <jdbcDriver libraryRef="PostgreSQLLib"/>
        <properties.postgresql
            serverName="${db.host}"
            portNumber="${db.port}"
            databaseName="${db.name}"
            user="${db.user}"
            password="${db.password}"/>
        <connectionManager maxPoolSize="5"/>
    </dataSource>

    <library id="PostgreSQLLib">
        <fileset dir="${shared.resource.dir}/jdbc" includes="*.jar"/>
    </library>

    <lraCoordinatorStore storeType="db"
                         dataSourceRef="jdbc/LraCoordinatorDS"
                         tablePrefix="lra_"/>
    -->


    <!-- ════════════════════════════════════════════════════════════════════
         LOGGING (optional)
         Uncomment to tune Liberty logging output.
         The Narayana coordinator uses JUL (java.util.logging).
         ════════════════════════════════════════════════════════════════════ -->
    <!--
    <logging traceSpecification="*=info:com.arjuna.*=fine:io.narayana.*=fine"
             consoleLogLevel="INFO"
             maxFileSize="20"
             maxFiles="5"/>
    -->


    <!-- ════════════════════════════════════════════════════════════════════
         SSL / HTTPS (optional)
         Uncomment and configure keystore if you need HTTPS.
         ════════════════════════════════════════════════════════════════════ -->
    <!--
    <keyStore id="defaultKeyStore" password="changeit"/>
    <ssl id="defaultSSLConfig" keyStoreRef="defaultKeyStore"/>
    -->

</server>
